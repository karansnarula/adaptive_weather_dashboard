rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Profile images: one file per user at users/{uid}/profile.jpg.
    // Only the owner can write/delete; any authed user can read.
    match /users/{uid}/profile.jpg {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
                    && request.auth.uid == uid;
    }

    // Discussion post images: one file per post at posts/{postId}/image.jpg.
    // Any authed user can read or upload; ownership enforcement happens at
    // the Firestore rules layer (only post author can create the doc that
    // references this URL).
    match /posts/{postId}/{file=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }
  }
}
